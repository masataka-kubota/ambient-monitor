{
  "name": "backend",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:ip": "wrangler dev --ip 0.0.0.0",
    "build:types": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "db:generate": "drizzle-kit generate",
    "db:migration:local": "wrangler d1 migrations apply ambient-monitor --local",
    "db:migration:remote": "wrangler d1 migrations apply ambient-monitor --remote",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local-studio.ts",
    "db:studio:remote": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.15",
    "@hono/eslint-config": "^2.1.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-istanbul": "3.2.4",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-drizzle": "^0.2.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3",
    "vitest": "~3.2.6",
    "wrangler": "^4.100.0"
  }
}
