{
  "name": "mobile",
  "version": "0.9.5",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --go",
    "dev": "APP_VARIANT=development bunx expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type-check": "tsc --noEmit",
    "build:backend-types": "bun run --filter backend build:types",
    "eas-build-post-install": "bun install --filter backend --frozen-lockfile && bun run --filter backend build:types"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/entypo": "^13.1.2",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.23",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "backend": "workspace:*",
    "buffer": "^6.0.3",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "i18next": "^25.10.10",
    "jotai": "^2.20.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.6",
    "react-native-ble-manager": "^12.5.0",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@types/node": "^25.9.3",
    "@types/react": "~19.2.17",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.69.0",
    "oxlint-config-universe": "^0.0.3",
    "typescript": "~5.9.3"
  }
