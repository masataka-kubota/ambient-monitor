{
  "name": "mobile",
  "version": "0.9.5",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --go",
    "dev": "APP_VARIANT=development bunx expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type-check": "tsc --noEmit",
    "build:backend-types": "bun run --filter backend build:types",
    "eas-build-post-install": "bun install --filter backend --frozen-lockfile && bun run --filter backend build:types"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/entypo": "^13.1.2",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "backend": "workspace:*",
    "buffer": "^6.0.3",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.21",
    "expo-web-browser": "~56.0.5",
    "i18next": "^25.10.10",
    "jotai": "^2.20.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.6.6",
    "react-native": "0.85.3",
    "react-native-ble-manager": "^12.5.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@types/node": "^25.9.4",
    "@types/react": "~19.2.17",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-config-universe": "^0.0.3",
    "typescript": "~6.0.3"
  }
}
